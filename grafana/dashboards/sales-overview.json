{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "ttp-sales-overview",
  "title": "Sales Overview",
  "tags": ["telecom-tower-power", "sales", "business"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tier",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, tier)",
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by tier (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tier) (rate(http_requests_total{tier=~\"$tier\"}[5m]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 } }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "id": 2,
      "title": "Successful requests by tier (last 24h)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tier) (increase(http_requests_total{status=~\"2..\",tier=~\"$tier\"}[24h]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "p95 latency by tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tier) (rate(http_request_duration_seconds_bucket{tier=~\"$tier\"}[5m])))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } } }
    },
    {
      "id": 4,
      "title": "Error rate (5xx) by tier",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tier) (rate(http_requests_total{status=~\"5..\",tier=~\"$tier\"}[5m])) / sum by (tier) (rate(http_requests_total{tier=~\"$tier\"}[5m]))",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 0.05 } }
    },
    {
      "id": 5,
      "title": "Rate-limit hits per minute by tier",
      "description": "Customers hitting their tier ceiling — strong upsell signal.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate_limit_hit_rate_per_minute{tier=~\"$tier\"}",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "id": 6,
      "title": "Top 10 endpoints (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (increase(http_requests_total{tier=~\"$tier\"}[24h])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "showHeader": true }
    },
    {
      "id": 7,
      "title": "Batch jobs active",
      "description": "Indicator of Pro+/Business+ engagement (batch is paid feature).",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "batch_jobs_active", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 8,
      "title": "Batch queue depth",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "batch_queue_depth", "legendFormat": "{{status}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 9,
      "title": "Batch p95 duration (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(batch_jobs_duration_seconds_bucket[24h])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 10,
      "title": "Conversion funnel (signup → checkout → key)",
      "description": "Stripe signup endpoint hit-rate vs successful key issuance.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum (increase(http_requests_total{endpoint=\"/billing/checkout\",status=~\"2..\"}[1h]))",
          "legendFormat": "checkout 2xx/h",
          "refId": "A"
        },
        {
          "expr": "sum (increase(http_requests_total{endpoint=\"/billing/webhook\",status=~\"2..\"}[1h]))",
          "legendFormat": "webhook 2xx/h",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
