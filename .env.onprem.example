# ─────────────────────────────────────────────────────────────────────
# .env.onprem.example — Self-hosted Enterprise template.
# Copy to `.env` next to docker-compose.onprem.yml and edit values.
# All AWS-specific knobs are intentionally absent.
# ─────────────────────────────────────────────────────────────────────

# CORS — list of allowed origins for the API (comma-separated).
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# ── Local LLM (Ollama / Llama-3) ──────────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=1024
OLLAMA_TEMPERATURE=0.7

# ── MinIO (S3-compatible object store) ───────────────────────────
MINIO_ROOT_USER=ttp_admin
S3_BUCKET_NAME=ttp-jobs

# ── PostgreSQL (used by docker-compose internally) ───────────────
POSTGRES_PASSWORD=telecom_secret_change_me

# ── Workers / batch ──────────────────────────────────────────────
PDF_WORKERS=4
ENABLE_DEMO_KEYS=false
OFFLINE_MODE=false

# ── In-house SMTP (optional; leave blank to disable email alerts) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
GF_SMTP_ENABLED=false
