{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
    },
    "deploy": {
        "startCommand": "/bin/sh -c \"envsubst '\\$PORT \\$BACKEND_URL' < /etc/nginx/nginx.conf.template > /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'\"",
        "healthcheckPath": "/",
        "healthcheckTimeout": 60,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3,
        "envVars": {
            "BACKEND_URL": {
                "description": "Internal URL of the backend API service (e.g. http://TELECOM-TOWER-POWER.railway.internal:8000)",
                "required": true
            }
        }
    }
}