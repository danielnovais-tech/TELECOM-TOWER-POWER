# ── ALB traffic (HTTP, ALB terminates TLS) ───────────────────
# www.telecomtowerpower.com.br and app.telecomtowerpower.com.br route
# through ALB which terminates TLS and forwards HTTP to EC2:80.
# api.telecomtowerpower.com.br also routes through ALB (failover CNAME).
# All default-rule traffic is handled by the :80 block below.
#
# Direct ALB target-group rules (bypass Caddy entirely):
#   monitoring.telecomtowerpower.com.br → ttp-grafana-tg:3001
#   prometheus.telecomtowerpower.com.br → ttp-prometheus-tg:9090
#
# Do NOT add bare domain blocks — Caddy would auto-enable HTTPS and
# create an HTTP→HTTPS redirect loop with the ALB.
:80 {
        # ── api.telecomtowerpower.com.br → all traffic to Railway API ──
        @api_host host api.telecomtowerpower.com.br
        handle @api_host {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }

        # ── docs.telecomtowerpower.com.br → MkDocs static build ──
        # The MkDocs site is built into /srv/docs inside the container
        # (see Dockerfile: COPY docs-site/site /srv/docs). If you deploy
        # the docs as a separate Railway static service, swap this for
        # a reverse_proxy to that service instead.
        @docs_host host docs.telecomtowerpower.com.br
        handle @docs_host {
                root * /srv/docs
                try_files {path} {path}/ {path}/index.html /index.html
                file_server
        }

        # ── www / app frontend: selective API routing + React SPA ──
        @api_routes path /api/* /health* /calculate* /towers* /batch* /jobs* /docs* /openapi.json /stripe* /usage* /api-key* /signup/free /signup/checkout /signup/status /login* /profile* /portal* /analyze* /plan_repeater* /export_report* /bedrock* /coverage* /srtm* /tenant* /admin/sales/overview* /admin/sales/tenants/*

        handle @api_routes {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /webhook* {
                reverse_proxy localhost:8001
        }
        handle /grafana* {
                reverse_proxy localhost:3001
        }
        # React frontend as default
        handle {
                reverse_proxy localhost:3000
        }
}
