# ── Direct HTTPS access (Caddy manages TLS cert) ────────────
ec2.telecomtowerpower.com.br {
        # API routes → Railway backend
        handle /api/* {
                uri strip_prefix /api
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /health* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /calculate* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /towers* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /batch* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /jobs* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /docs* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /openapi.json {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /stripe* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /usage* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /api-key* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /signup* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /login* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /profile* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /portal* {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /webhook* {
                reverse_proxy localhost:8001
        }
        handle /grafana* {
                reverse_proxy localhost:3001
        }
        # React frontend as default
        handle {
                reverse_proxy localhost:3000
        }
}

