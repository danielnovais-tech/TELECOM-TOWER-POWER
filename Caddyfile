# ── ALB traffic (HTTP, ALB terminates TLS) ───────────────────
# www.telecomtowerpower.com.br and app.telecomtowerpower.com.br route
# through ALB which terminates TLS and forwards HTTP to EC2:80.
# api.telecomtowerpower.com.br also routes through ALB (failover CNAME).
# All default-rule traffic is handled by the :80 block below.
#
# Direct ALB target-group rules (bypass Caddy entirely):
#   monitoring.telecomtowerpower.com.br → ttp-grafana-tg:3001
#   prometheus.telecomtowerpower.com.br → ttp-prometheus-tg:9090
#
# Do NOT add bare domain blocks — Caddy would auto-enable HTTPS and
# create an HTTP→HTTPS redirect loop with the ALB.
:80 {
        # ── api.telecomtowerpower.com.br → all traffic to Railway API ──
        @api_host host api.telecomtowerpower.com.br
        handle @api_host {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }

        # ── docs.telecomtowerpower.com.br → MkDocs static build ──
        # The MkDocs site is built into /srv/docs inside the container
        # (see Dockerfile: COPY docs-site/site /srv/docs). If you deploy
        # the docs as a separate Railway static service, swap this for
        # a reverse_proxy to that service instead.
        @docs_host host docs.telecomtowerpower.com.br
        handle @docs_host {
                root * /srv/docs
                try_files {path} {path}/ {path}/index.html /index.html
                file_server
        }

        # ── /tiles/* → Planetiler PMTiles on S3 ──
        # The monthly planetiler-build workflow uploads brazil.pmtiles to
        # s3://telecom-tower-power-results/tiles/. Caddy reverse-proxies
        # any /tiles/* request to the bucket so the SPA can fetch a
        # stable origin URL (HTTP Range requests for PMTiles work
        # natively over S3).
        #
        # Required bucket policy (one-time, manual): allow public
        # s3:GetObject on arn:aws:s3:::telecom-tower-power-results/tiles/*.
        # Without it Caddy will simply forward S3's 403.
        @tiles path /tiles/*
        handle @tiles {
                # Strip /tiles/ prefix so /tiles/brazil.pmtiles → /tiles/brazil.pmtiles
                # on the bucket (object key already starts with tiles/).
                header {
                        Access-Control-Allow-Origin "*"
                        Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
                        Access-Control-Allow-Headers "Range, If-Match, If-None-Match"
                        Access-Control-Expose-Headers "Content-Length, Content-Range, ETag, Accept-Ranges"
                        Cache-Control "public, max-age=2592000"
                }
                reverse_proxy https://telecom-tower-power-results.s3.sa-east-1.amazonaws.com {
                        header_up Host telecom-tower-power-results.s3.sa-east-1.amazonaws.com
                }
        }

        # ── www / app frontend: selective API routing + React SPA ──
        @api_routes path /api/* /health* /calculate* /towers* /batch* /jobs* /docs* /openapi.json /stripe* /usage* /api-key* /signup/free /signup/checkout /signup/status /login* /profile* /portal* /analyze* /plan_repeater* /export_report* /bedrock* /coverage* /srtm* /tenant* /admin/sales/overview* /admin/sales/tenants/* /admin/impersonate/* /admin/cache/*

        handle @api_routes {
                reverse_proxy https://web-production-90b1f.up.railway.app {
                        header_up Host web-production-90b1f.up.railway.app
                }
        }
        handle /webhook* {
                reverse_proxy localhost:8001
        }
        # Grafana is reached via the dedicated subdomain
        # (monitoring.telecomtowerpower.com.br → ttp-grafana-tg:3001 at the ALB).
        # No /grafana* path handler here: a path-prefix proxy without
        # GF_SERVER_SERVE_FROM_SUB_PATH causes Grafana to 302 to /login,
        # which the default handler below would then serve as the React SPA.
        # React frontend as default
        handle {
                reverse_proxy localhost:3000
        }
}
