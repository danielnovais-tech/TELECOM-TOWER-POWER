# ──────────────────────────────────────────────────────────
# TELECOM TOWER POWER – Environment Variables
# Copy this file to .env and fill in production values.
#
# SECURITY: Restrict .env to owner-only access on EC2/servers:
#   cp .env.example .env && chmod 600 .env
#
# DOCKER COMPOSE SECRETS (preferred):
#   For Docker deployments, sensitive values should go in secrets/ files
#   instead of this .env file.  See secrets/README.md for details.
#   Run: cd secrets && bash init_secrets.sh
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL (production) — use asyncpg driver for telecom_tower_power_db.py
# Railway: provided automatically via PostgreSQL plugin
# AWS: manually configure RDS endpoint
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=

# SQLite fallback (local development only — used when DATABASE_URL is unset)
# TOWER_DB_PATH=./towers.db

# ── Redis (required for batch job queue) ─────────────────
# Railway: Railway Redis plugin
# AWS: ElastiCache endpoint
REDIS_URL=redis://localhost:6379

# ── S3 Storage (batch result ZIPs) ───────────────────────
# Leave S3_BUCKET_NAME blank to use local /tmp fallback
# Railway/AWS: standard S3 bucket
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── API Server ───────────────────────────────────────────
# Server port (auto-set by Railway; override for local Docker)
PORT=8000

# Path to SRTM .hgt elevation tiles
SRTM_DATA_DIR=./srtm_data

# CORS origins (comma-separated)
# In production, set to your actual domain(s):
#   CORS_ORIGINS=https://app.telecomtowerpower.com.br,https://api.telecomtowerpower.com.br
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# Rate limits (requests per minute per tier)
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# API key override – JSON dict mapping key → tier
# When set, supplements the dynamically-provisioned Stripe keys.
# Example: VALID_API_KEYS={"prod-key-001":"pro","prod-key-002":"enterprise"}
VALID_API_KEYS=

# ── Stripe Billing ───────────────────────────────────────
# Required for paid signup flow. Leave blank to disable billing.
# All values come from your Stripe Dashboard → Developers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# URL the Stripe Checkout redirects back to after payment
FRONTEND_URL=http://localhost:3000

# Persistent API key store (JSON file path)
KEY_STORE_PATH=./key_store.json

# ── SMTP / Amazon SES (Grafana & Alertmanager email alerts) ─
# Amazon SES SMTP credentials (IAM → SMTP credentials in the SES console)
# Region endpoint: email-smtp.<region>.amazonaws.com:587
SMTP_HOST=email-smtp.sa-east-1.amazonaws.com:587
SMTP_FROM=alerts@telecomtowerpower.com.br
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=

# SES sender for transactional emails (welcome email with API key)
SES_SMTP_HOST=email-smtp.sa-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_FROM_ADDRESS=no-reply@telecomtowerpower.com.br

# Email recipient for critical alert notifications
ALERT_EMAIL_TO=daniel.novais@sempreceub.com

# ── Slack / PagerDuty (Alertmanager & Grafana) ───────────
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts
PAGERDUTY_INTEGRATION_KEY=

# Public Alertmanager URL (used in alert link templates / email footers)
ALERTMANAGER_EXTERNAL_URL=https://monitoring.telecomtowerpower.com.br

# ── Streamlit Frontend ───────────────────────────────────
# streamlit_app.py uses API_URL; frontend.py uses API_BASE_URL
API_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000

# ── React/Vite Frontend (build-time only) ────────────────
# Baked into the static bundle at `npm run build` — DO NOT use for secrets.
VITE_API_KEY=

# ── Amazon Bedrock (LLM-assisted summaries) ──────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# ── SageMaker Coverage Inference (optional) ──────────────
# Set both to enable remote inference; leave blank to use local model.
SAGEMAKER_COVERAGE_ENDPOINT=
SAGEMAKER_REGION=us-east-1

# ── Coverage Model (local fallback) ──────────────────────
# Path to the .npz model file used by coverage_predict.py
COVERAGE_MODEL_PATH=coverage_model.npz
# Optional: S3 URI to download/refresh the model on container start
COVERAGE_MODEL_S3_URI=

# ── OpenTelemetry (tracing) ──────────────────────────────
# Disabled by default. Set OTEL_ENABLED=true and supply an OTLP endpoint
# (e.g. Grafana Tempo, Jaeger, or AWS ADOT collector) to opt in.
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_SERVICE_NAME=telecom-tower-power-api
# Head sampling ratio (0.0-1.0). Default 0.05 = 5% of traces sampled.
OTEL_TRACES_SAMPLER_ARG=0.05

# ── PDF Generation ───────────────────────────────────────
# Number of WeasyPrint worker processes for /report/pdf endpoint
PDF_WORKERS=2

# ── SRTM Elevation Cache (optional separate Redis) ───────
# Falls back to REDIS_URL when blank
SRTM_REDIS_URL=

# ── Failover / DR ────────────────────────────────────────
# Public hostname of the Railway secondary used by Route 53 failover record
RAILWAY_DNS=web-production-90b1f.up.railway.app

# ── Demo / sandbox controls ──────────────────────────────
# When true, exposes seeded demo API keys at /docs landing — production: false
ENABLE_DEMO_KEYS=false
# JSON map of demo api_key → tier, e.g. {"demo-free":"free","demo-pro":"pro"}
DEMO_KEYS=
# JSON map exposed to /demo UI (subset of DEMO_KEYS)
DEMO_KEYS_UI=
# Rate limit applied to demo keys (req/min)
DEMO_RATE_LIMIT=20
# When true, exposes /debug/* endpoints — production: false
ENABLE_DEBUG_ENDPOINTS=false
# Free-form environment label used in logs and Grafana dashboards
APP_ENV=production

# ── Admin API ────────────────────────────────────────────
# JSON list of API keys with admin scope, e.g. ["admin-prod-001"]
ADMIN_API_KEYS=

# ── GraphQL ──────────────────────────────────────────────
# Expose GraphiQL playground (production: false)
GRAPHQL_GRAPHIQL=false

# ── Tier-specific rate limits & PDF quotas ───────────────
RATE_LIMIT_STARTER=30
RATE_LIMIT_BUSINESS=300
RATE_LIMIT_ULTRA=3000
PDF_QUOTA_FREE=3
PDF_QUOTA_STARTER=20
PDF_QUOTA_PRO=100
PDF_QUOTA_BUSINESS=500
PDF_QUOTA_ENTERPRISE=5000
PDF_QUOTA_ULTRA=50000

# ── Stripe additional price IDs ──────────────────────────
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_BUSINESS_ANNUAL=
STRIPE_PRICE_ENTERPRISE_ANNUAL=

# ── Stripe webhook standalone service ────────────────────
# Port stripe_webhook_service.py listens on when run as separate container
WEBHOOK_PORT=8002

# ── Bedrock LLM tuning ───────────────────────────────────
BEDROCK_MAX_TOKENS=512
BEDROCK_TEMPERATURE=0.2
# Optional bearer token for Bedrock proxy auth (leave blank for SigV4)
AWS_BEARER_TOKEN_BEDROCK=

# ── AWS Cognito SSO (optional) ───────────────────────────
# Configure all five to enable Cognito-based login. Leave blank to disable.
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_APP_CLIENT_SECRET=
COGNITO_DOMAIN=
# SSO HTTP timeouts (seconds)
SSO_JWKS_HTTP_TIMEOUT_S=5
SSO_JWKS_TTL_S=3600
SSO_OAUTH_HTTP_TIMEOUT_S=10

# ── API Gateway / Lambda deployment ──────────────────────
# Base path prefix when deployed behind API Gateway (e.g. "v1")
API_GATEWAY_BASE_PATH=

# ── RDS / Lambda warm-pool ───────────────────────────────
# Set when Lambda or worker connects via RDS Proxy
RDS_PROXY_HOST=
RDS_PROXY_PORT=5432
# Optional alternative to DATABASE_URL
DB_NAME=
DB_USER=

# ── SQS (async batch jobs via Lambda) ────────────────────
SQS_QUEUE_URL=
SQS_QUEUE_URL_PRIORITY=

# ── S3 advanced options ──────────────────────────────────
# Object key prefix inside the bucket
S3_PREFIX=batch/
# Presigned URL expiry (seconds)
S3_PRESIGNED_EXPIRY=3600
# Local fallback dir when S3_BUCKET_NAME is blank
RESULT_STORAGE_DIR=/tmp/ttp-results

# ── Job processing tunables ──────────────────────────────
JOB_RESULTS_DIR=/tmp/ttp-jobs
JOB_HEARTBEAT_INTERVAL=30
STALE_JOB_TIMEOUT=900
STALE_JOB_REAPER_INTERVAL=120
QUEUE_METRICS_INTERVAL=15
MAX_BATCH_ROWS=10000
MAX_UPLOAD_BYTES=10485760
REPEATER_JOBS_MAX=1000
REPEATER_JOBS_TTL_S=86400

# ── Audit log ────────────────────────────────────────────
# In-memory ring-buffer max entries (DB is the source of truth)
AUDIT_MEM_MAX=1000

# ── Hop / signal-path cache ──────────────────────────────
HOP_CACHE_LRU_MAX=10000
HOP_CACHE_TTL_S=3600
# Optional Redis backing for cross-process hop cache; falls back to LRU
HOP_CACHE_REDIS_URL=

# ── Terrain / SRTM ───────────────────────────────────────
# Alternative path key (some scripts use SRTM_DIR instead of SRTM_DATA_DIR)
SRTM_DIR=./srtm_data
# ISO-3166 alpha-2 country code for tile prefetch (BR = Brazil)
SRTM_PREFETCH_COUNTRY=BR
TERRAIN_API_TIMEOUT_S=10
TERRAIN_REDIS_TTL=86400

# ── OpenElevation client ─────────────────────────────────
OE_SINGLE_TIMEOUT_S=5
OE_BATCH_TIMEOUT_S=30
OE_BASE_DELAY_S=0.5
OE_MAX_RETRIES=3

# ── Geocoder cache ───────────────────────────────────────
GEOCODE_CACHE_PATH=./geocode_cache_br.json

# ── OpenCelliD enrichment (optional) ─────────────────────
OPENCELLID_TOKEN=

# ── Tower-loader scripts (load_towers.py) ────────────────
LOAD_TOWERS_URL=
LOAD_TOWERS_API_KEY=

# ── Frontend (Vite build-time) ───────────────────────────
# Default API base baked into the React bundle
VITE_API_BASE=https://api.telecomtowerpower.com.br

# ── docker-compose interpolation only ────────────────────
# Used by docker-compose.yml's ${POSTGRES_PASSWORD} for the local Postgres
# service. Production deployments use DATABASE_URL above and ignore this.
POSTGRES_PASSWORD=

# ── Audit log: KMS envelope encryption ───────────────────
# When set, audit_log.metadata_json is encrypted with a KMS-wrapped DEK.
# See scripts/setup_audit_kms.sh for one-time provisioning. Region defaults
# to AWS_REGION / sa-east-1 when unset.
AUDIT_KMS_KEY_ID=
AUDIT_KMS_REGION=
# DEK reuse policy (envelope encryption tunables). Defaults are safe;
# only override under cryptographer guidance.
KMS_DEK_TTL_SECONDS=
KMS_DEK_MAX_USES=

# ── Audit log: retention windows (days) ──────────────────
# Applied by scripts/audit_log_prune.py from the daily workflow.
AUDIT_RETENTION_SECURITY_DAYS=365
AUDIT_RETENTION_OPERATIONAL_DAYS=90

# ── Admin step-up MFA ────────────────────────────────────
# Comma-separated list of "email:base32_secret" pairs. Required for
# /admin/impersonate and /admin/sales/tenants/{prefix}. Generate with
# scripts/admin_totp_enroll.py.
ADMIN_TOTP_SECRETS=

# ── Free-tier signup protection ──────────────────────────
# Cloudflare Turnstile (server validates token; site key is public).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Per-IP signup rate cap (default 5 if unset).
SIGNUP_FREE_RATE_LIMIT_PER_HOUR=5

# ── itmlogic (NTIA Longley-Rice / ITM v1.2.2) RF engine ─────
# Feature flag to disable engine without uninstalling. Defaults to
# enabled. Set to 1 to make `rf_engines.get_engine("itmlogic")` raise.
ITMLOGIC_DISABLED=
# ITM climate code (1=equatorial, 2=continental subtropical,
# 3=maritime subtropical, 4=desert, 5=continental temperate (default),
# 6=maritime temperate over land, 7=maritime temperate over sea).
ITMLOGIC_CLIMATE=5
# Surface refractivity at sea level (N-units). 314 ≈ continental
# temperate; tropical/coastal sites typically 320-340.
ITMLOGIC_NS0=314
# Ground constants — relative permittivity (default 15) and
# conductivity in S/m (default 0.005). "Average ground" defaults.
ITMLOGIC_EPS=15
ITMLOGIC_SGM=0.005

# ── ITU-R P.1812 propagation engine ──────────────────────
# Set to 1 to disable the engine without uninstalling Py1812.
ITU_P1812_DISABLED=
# Polarization: 1=horizontal, 2=vertical (default). Required by P.1812.
ITU_P1812_POL=2
# Default radio-climatic zone when MapBiomas/coastal lookup is absent.
# 1=Sea, 3=Coastal land, 4=Inland (default per ITU-R).
ITU_P1812_ZONE_DEFAULT=4
# Time/location percentages for which the loss is not exceeded (1..50
# for time, 1..99 for location). 50/50 = median path loss.
ITU_P1812_TIME_PCT=50
ITU_P1812_LOC_PCT=50
# Per-link Redis cache TTL (seconds). Default 7 days.
ITU_P1812_REDIS_TTL_SEC=604800
# Optional dedicated Redis URL; falls back to REDIS_URL when unset.
ITU_P1812_REDIS_URL=

# ── MapBiomas land-cover clutter ─────────────────────────
# Path to the Brazil-coverage GeoTIFF (cloud-mounted on EFS in prod).
# When unset, the clutter lookup short-circuits to "unknown" and the
# RF engines fall back to ITU_P1812_ZONE_DEFAULT.
MAPBIOMAS_RASTER_PATH=
# Optional dedicated Redis URL for clutter cache; falls back to REDIS_URL.
MAPBIOMAS_REDIS_URL=
# Clutter cache TTL (seconds). Default 30 days — land cover is stable.
MAPBIOMAS_REDIS_TTL_S=2592000
# In-process LRU cap for raster window reads.
MAPBIOMAS_LRU_MAX=8192

# ── Planet Labs satellite-change robot ───────────────────
# Used by scripts/satellite_change_robot.py (and the
# .github/workflows/satellite-change.yml weekly cron) to query Planet's
# Data API quick-search endpoint for fresh PSScene imagery over each
# tower footprint. HTTP-Basic auth: the key is sent as username with an
# empty password. Get one from https://www.planet.com/account/#/apikeys.
# Unset = robot still runs but emits an empty report (no-api-key).
PLANET_API_KEY=

# ── Sionna ML propagation engine (NVIDIA, optional) ──────
# Disabled by default — requires TF + GPU + a trained .tflite. Flip to 0
# only on hosts where SIONNA_MODEL_PATH points at a real model.
SIONNA_DISABLED=1
SIONNA_MODEL_PATH=/srv/models/sionna_model.tflite

# ── Signal-Server engine (W3AXL fork, GPL-2.0, subprocess) ────
# Subprocess wall-clock cap (seconds).
SIGNAL_SERVER_TIMEOUT_S=8.0
# Algorithm flag forwarded to signalserverHD: itm (default), itwom,
# hata, ericsson, cost-hata, sui, fspl. See upstream README.
SIGNAL_SERVER_MODEL=itm
# Path to the SRTM .sdf tile directory. Signal-Server reads its own
# DEM via `-sdf <dir>`; without it the engine assumes flat sea-level
# terrain and the loss values are physically meaningless.
SIGNAL_SERVER_SDF_DIR=
# Explicit opt-in: set to 1 ONLY after building Signal-Server with
# scripts/build_signal_server.sh, which applies signal_server_json.patch
# (adds the `-json` flag the adapter parses). Stock upstream binaries
# do not emit JSON; leaving this unset keeps the engine disabled.
SIGNAL_SERVER_JSON_FORK=

# ── rf-signals engine (clean-room, see docs/rf-engines.md) ─
# The binary lives in this repo at rf_signals/ — build with
# `bash scripts/build_rf_signals.sh ~/.local`. Adapter resolution
# order: $RF_SIGNALS_BIN → /usr/local/bin/rfsignals-cli → PATH.
# Subprocess wall-clock cap (seconds).
RF_SIGNALS_BIN=
RF_SIGNALS_TIMEOUT_S=5.0
# Boot-time hydration: when RF_SIGNALS_S3_URL points at the public-read
# artefact published by the rf-signals-publish CI workflow,
# entrypoint.sh fetches the binary into ${RF_SIGNALS_BIN_DIR:-/opt/rfsignals}
# and exports RF_SIGNALS_BIN automatically. Optional sha256 check.
# Default URL (most recent build):
#   https://telecom-tower-power-results.s3.sa-east-1.amazonaws.com/bin/rfsignals-cli
RF_SIGNALS_S3_URL=
RF_SIGNALS_S3_SHA256=
RF_SIGNALS_BIN_DIR=

# ── Coverage band-specific ML models (optional) ──────────
# Local directory holding per-band .npz models loaded by coverage_predict.
# When empty, falls back to the bundled coverage_model.npz.
COVERAGE_BAND_MODEL_DIR=
# S3 prefix to sync band models from at boot (s3://bucket/path/).
COVERAGE_BAND_MODELS_S3_PREFIX=

# ── hop_cache stale-tower invalidation (gap C, 2026-05) ──
# Optional override for the TTL applied when satellite-change marks
# towers as stale. Default 30 days. Only honoured when the cache is
# Redis-backed; in-memory backends ignore stale markers entirely.
HOP_CACHE_STALE_TTL_S=

# ── Sionna feature schema toggle (gap D, 2026-05) ────────
# Set to "v2" to enable the 30-dim feature vector that includes the
# Planet PSScene NDVI-delta channel. Default "v1" keeps the 28-dim
# vector that the production TFLite artefact was trained on. Bumping
# this without retraining causes sionna_engine to fail closed because
# the sidecar schema_version + feature_dim no longer match.
SIONNA_FEATURES_VERSION=
# Override the path to the sidecar JSON (defaults to a sibling of the
# TFLite model). Useful when the artefact lives outside the standard
# layout (e.g. when running the trainer locally with a temp model).
SIONNA_FEATURES_PATH=
# Path to the JSON cache populated by scripts/refresh_ndvi_cache.py.
# When unset the extractor uses planet_ndvi_cache.json at the repo
# root; missing files degrade to "all lookups missing" silently so
# the missing flag in the feature vector does its job.
PLANET_NDVI_CACHE=

# ── satellite-change → hop_cache invalidator (gap C) ─────
# Default report path consumed by scripts/invalidate_rf_cache.py.
# Overridden in CI by passing --report explicitly.
PLANET_REPORT=
# Base URL of the running TTP API (used by invalidate_rf_cache.py to
# POST /admin/cache/invalidate-towers). Stored as a GH Actions secret
# in production so the satellite-change workflow can close the loop.
TTP_API_URL=
# Admin API key with the cache-invalidate scope. Required only by the
# CI invalidator script; the API itself reads its own ADMIN_API_KEYS.
TTP_ADMIN_API_KEY=

# ── Offline / air-gapped mode ────────────────────────────────
# Set TTP_OFFLINE=1 to forbid ALL outbound calls to paid third
# parties (Stripe checkout/webhook, Amazon Bedrock, Planet Labs
# satellite-change API). Local-only services keep working: SRTM
# tile cache, MapBiomas raster, RF engines (P.1812, ITM-logic,
# Sionna with on-disk model), Postgres / Redis, and the
# RadioPlanner / Atoll / Planet exporters.
#
# Useful for on-prem / sovereign deployments and CI without
# secrets. Stripe endpoints respond with HTTP 503 + offline=true;
# Bedrock returns a canned "AI Playground disabled" message.
TTP_OFFLINE=
