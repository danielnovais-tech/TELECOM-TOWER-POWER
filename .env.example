# ──────────────────────────────────────────────────────────
# TELECOM TOWER POWER – Environment Variables
# Copy this file to .env and fill in production values.
# ──────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# PostgreSQL (production) — use asyncpg driver for telecom_tower_power_db.py
# Render: provided automatically via Internal Database link
# Railway: provided automatically via PostgreSQL plugin
# AWS: manually configure RDS endpoint
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=

# SQLite fallback (local development only — used when DATABASE_URL is unset)
# TOWER_DB_PATH=./towers.db

# ── Redis (required for batch job queue) ─────────────────
# Render: Render Redis add-on (internal URL)
# Railway: Railway Redis plugin
# AWS: ElastiCache endpoint
REDIS_URL=redis://localhost:6379

# ── S3 Storage (batch result ZIPs) ───────────────────────
# Leave S3_BUCKET_NAME blank to use local /tmp fallback
# Render: use Cloudflare R2 or external S3
# Railway/AWS: standard S3 bucket
S3_BUCKET_NAME=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── API Server ───────────────────────────────────────────
# Server port (auto-set by Render/Railway; override for local Docker)
PORT=8000

# Path to SRTM .hgt elevation tiles
SRTM_DATA_DIR=./srtm_data

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Rate limits (requests per minute per tier)
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=100
RATE_LIMIT_ENTERPRISE=1000

# API key override – JSON dict mapping key → tier
# When set, supplements the dynamically-provisioned Stripe keys.
# Example: VALID_API_KEYS={"prod-key-001":"pro","prod-key-002":"enterprise"}
VALID_API_KEYS=

# ── Stripe Billing ───────────────────────────────────────
# Required for paid signup flow. Leave blank to disable billing.
# All values come from your Stripe Dashboard → Developers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# URL the Stripe Checkout redirects back to after payment
FRONTEND_URL=http://localhost:3000

# Persistent API key store (JSON file path)
KEY_STORE_PATH=./key_store.json

# ── Streamlit Frontend ───────────────────────────────────
# streamlit_app.py uses API_URL; frontend.py uses API_BASE_URL
API_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000
