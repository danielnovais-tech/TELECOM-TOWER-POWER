{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
    },
    "deploy": {
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 5,
        "envVars": {
            "REDIS_ADDR": {
                "description": "Redis connection URL for metrics collection (e.g. redis://host:port)",
                "required": true
            }
        }
    }
}