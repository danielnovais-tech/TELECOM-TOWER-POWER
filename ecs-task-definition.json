{
  "family": "telecom-tower-power",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.AWS_REGION.amazonaws.com/telecom-tower-power:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8000"
        },
        {
          "name": "CORS_ORIGINS",
          "value": "https://app.telecomtowerpower.com.br,https://www.telecomtowerpower.com.br,https://api.telecomtowerpower.com.br,https://app.telecomtowerpower.com,https://api.telecomtowerpower.com"
        },
        {
          "name": "FRONTEND_URL",
          "value": "https://app.telecomtowerpower.com.br"
        },
        {
          "name": "S3_REGION",
          "value": "AWS_REGION"
        },
        {
          "name": "MAX_BATCH_ROWS",
          "value": "500"
        },
        {
          "name": "ENABLE_DEMO_KEYS",
          "value": "true"
        },
        {
          "name": "BEDROCK_REGION",
          "value": "us-east-1"
        },
        {
          "name": "BEDROCK_MODEL_ID",
          "value": "amazon.nova-micro-v1:0"
        },
        {
          "name": "SAGEMAKER_REGION",
          "value": "us-east-1"
        },
        {
          "name": "COVERAGE_MODEL_PATH",
          "value": "/app/coverage_model.npz"
        },
        {
          "name": "COVERAGE_MODEL_S3_URI",
          "value": ""
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/REDIS_URL"
        },
        {
          "name": "SRTM_REDIS_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/SRTM_REDIS_URL"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/S3_BUCKET_NAME"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/STRIPE_SECRET_KEY"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/STRIPE_WEBHOOK_SECRET"
        },
        {
          "name": "STRIPE_PRICE_PRO",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/STRIPE_PRICE_PRO"
        },
        {
          "name": "STRIPE_PRICE_ENTERPRISE",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/STRIPE_PRICE_ENTERPRISE"
        },
        {
          "name": "VALID_API_KEYS",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/VALID_API_KEYS"
        },
        {
          "name": "SLACK_WEBHOOK_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/SLACK_WEBHOOK_URL"
        },
        {
          "name": "SAGEMAKER_COVERAGE_ENDPOINT",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/SAGEMAKER_COVERAGE_ENDPOINT"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "srtm-data",
          "containerPath": "/app/srtm_data"
        },
        {
          "sourceVolume": "job-results",
          "containerPath": "/app/job_results"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/telecom-tower-power",
          "awslogs-region": "AWS_REGION",
          "awslogs-stream-prefix": "api"
        }
      }
    },
    {
      "name": "worker",
      "image": "ACCOUNT_ID.dkr.ecr.AWS_REGION.amazonaws.com/telecom-tower-power:latest",
      "essential": true,
      "command": [
        "python",
        "batch_worker.py",
        "--poll-interval",
        "2"
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/DATABASE_URL"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/REDIS_URL"
        },
        {
          "name": "SRTM_REDIS_URL",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/SRTM_REDIS_URL"
        },
        {
          "name": "S3_BUCKET_NAME",
          "valueFrom": "arn:aws:ssm:AWS_REGION:ACCOUNT_ID:parameter/telecom-tower-power/S3_BUCKET_NAME"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "srtm-data",
          "containerPath": "/app/srtm_data"
        },
        {
          "sourceVolume": "job-results",
          "containerPath": "/app/job_results"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/telecom-tower-power",
          "awslogs-region": "AWS_REGION",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "srtm-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "EFS_ID",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "AP_SRTM_ID",
          "iam": "ENABLED"
        }
      }
    },
    {
      "name": "job-results",
      "efsVolumeConfiguration": {
        "fileSystemId": "EFS_ID",
        "rootDirectory": "/",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "AP_JOBS_ID",
          "iam": "ENABLED"
        }
      }
    }
  ]
}